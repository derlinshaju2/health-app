{
  "version": 2,
  "builds": [
    {
      "src": "health-backend/src/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "health-backend/src/app.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "health-backend/src/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "health-backend/src/app.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}