{
  "version": 2,
  "public": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[[...path]].js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
