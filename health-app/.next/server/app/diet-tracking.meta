{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/diet-tracking/layout,_N_T_/diet-tracking/page,_N_T_/diet-tracking"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/diet-tracking/__PAGE__",
    "/diet-tracking",
    "/_index",
    "/_head"
  ]
}